{
  "manifest_version": 3,
  "name": "URL Postfix Manager",
  "version": "1.0.0",
  "description": "Добавляет сохранённые query-параметры к текущему URL. Список сортируется по частоте использования.",
  "permissions": ["storage", "activeTab", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "URL Postfix Manager",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
